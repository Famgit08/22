{
  "info": {
    "name": "Практика HTTP — Зиберева А.А.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET Все посты",
      "request": {
        "method": "GET",
        "url": "https://jsonplaceholder.typicode.com/posts"
      }
    },
    {
      "name": "GET Один пост №5",
      "request": {
        "method": "GET",
        "url": "https://jsonplaceholder.typicode.com/posts/5"
      }
    },
    {
      "name": "GET Посты пользователя 1",
      "request": {
        "method": "GET",
        "url": "https://jsonplaceholder.typicode.com/posts?userId=1"
      }
    },
    {
      "name": "GET Комментарии к посту 3",
      "request": {
        "method": "GET",
        "url": "https://jsonplaceholder.typicode.com/posts/3/comments"
      }
    },
    {
      "name": "POST Создать пост",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"title\": \"Мой новый пост\",\n    \"body\": \"Текст поста\",\n    \"userId\": 1\n}"
        },
        "url": "https://jsonplaceholder.typicode.com/posts"
      }
    },
    {
      "name": "PUT Полное обновление поста 5",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"id\": 5,\n    \"title\": \"Обновлённый заголовок\",\n    \"body\": \"Новый текст\",\n    \"userId\": 1\n}"
        },
        "url": "https://jsonplaceholder.typicode.com/posts/5"
      }
    },
    {
      "name": "PATCH Частичное обновление поста 5",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"title\": \"Изменённый заголовок\"\n}"
        },
        "url": "https://jsonplaceholder.typicode.com/posts/5"
      }
    },
    {
      "name": "DELETE Удалить пост 5",
      "request": {
        "method": "DELETE",
        "url": "https://jsonplaceholder.typicode.com/posts/5"
      }
    }
  ]
